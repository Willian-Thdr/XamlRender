<Window x:Class="XamlRender.Source.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XamlRender"
        mc:Ignorable="d"
        Title="XamlRender" 
        Background="#f0ecd7"
        Height="450" Width="800">

        <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="LoadXaml">
            <Label Content="Xaml Render" Canvas.Top="20" Canvas.Left="275" Width="250"
            FontSize="24pt" HorizontalContentAlignment="Center"/>

            <Button Content="Carregar arquivo" Canvas.Left="275" BorderThickness="2" BorderBrush="#39bbe2"
            Width="250" Canvas.Top="100" FontSize="18pt" Background="#50ffffff" Click="LoadButton"/>
        </Canvas>
</Window>
